# LaunchDarkly SDK Keys
LD_SDK_KEY=YOUR_LD_SERVER_SIDE_KEY
LD_CLIENT_SIDE_ID=YOUR_LD_CLIENT_SIDE_KEY

# LaunchDarkly Project
LD_PROJECT_KEY=kevinc-new-demo-app

# AWS / DynamoDB
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# Backend
FLASK_PORT=5001
FLASK_ENV=development

# Frontend (served by backend in dev, or standalone)
FRONTEND_PORT=3000
FRONTEND_URL=http://localhost:3000

# Default skin on startup: retail | health | financial
DEFAULT_SKIN=retail
